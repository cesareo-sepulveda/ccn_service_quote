<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="ccn_view_rubro_bucket_tree" model="ir.ui.view">
      <field name="name">ccn.rubro.bucket.tree</field>
      <field name="model">ccn.service.quote.scope.rubro</field>
      <field name="arch" type="xml">
        <list string="Buckets Sitio/Servicio/Rubro">
          <field name="quote_id"/>
          <field name="site_id"/>
          <field name="service_type"/>
          <field name="rubro_id"/>
          <field name="rubro_code" optional="hide"/>
          <field name="currency_id" invisible="1"/>
        </list>
      </field>
    </record>

    <record id="ccn_view_rubro_bucket_form" model="ir.ui.view">
      <field name="name">ccn.rubro.bucket.form</field>
      <field name="model">ccn.service.quote.scope.rubro</field>
      <field name="arch" type="xml">
        <form string="Bucket Sitio/Servicio/Rubro">
          <sheet>
            <group>
              <field name="quote_id" options="{'no_open': True}"/>
              <field name="site_id"/>
              <field name="service_type"/>
              <field name="rubro_id"/>
              <field name="rubro_code" readonly="1"/>
            </group>
            <notebook>
              <page string="Líneas">
                <field name="line_ids" mode="list">
                  <list editable="bottom">
                    <field name="product_id" options="{'no_open': True, 'no_create': True, 'no_create_edit': True}"/>
                    <field name="quantity"/>
                    <field name="tabulator_percent"/>
                    <field name="price_unit_final" readonly="1"/>
                    <field name="total_price" readonly="1"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="ccn_action_rubro_buckets" model="ir.actions.act_window">
      <field name="name">Buckets Sitio/Servicio/Rubro</field>
      <field name="res_model">ccn.service.quote.scope.rubro</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
